NODE_ENV=production
DISCORD_TOKEN=
DISCORD_APPLICATION_ID=
DEEPL_API_KEY=
DEEPL_API_BASE_URL=https://api.deepl.com
DATA_DIR=/data/app
DATABASE_PATH=/data/app/bot.sqlite
DEFAULT_SOURCE_LANGUAGE=EN
DEFAULT_TARGET_LANGUAGE=RU
LOG_LEVEL=info
ADMIN_ROLE_IDS=
LOG_CHANNEL_ID=
MAX_CONCURRENT_JOBS=2
MAX_RETRY_ATTEMPTS=6
JOB_LEASE_SECONDS=300
RETRY_BASE_SECONDS=60
PUBLISH_ORIGINAL_ON_EXHAUSTED_TRANSIENT_FAILURE=true
HEALTH_SERVER_ENABLED=true
METRICS_ENABLED=false
SOURCE_DUPLICATE_WINDOW_SECONDS=900
ATTACHMENT_MIRROR_MAX_BYTES=20000000
RAILWAY_VOLUME_MOUNT_PATH=/data
PORT=8080
RAILWAY_RUN_UID=0
RAILWAY_HEALTHCHECK_TIMEOUT_SEC=60
RAILWAY_DEPLOYMENT_DRAINING_SECONDS=20
RAILWAY_DEPLOYMENT_OVERLAP_SECONDS=0
DEV_GUILD_ID=
MOCK_DEEPL=false
SKIP_STARTUP_DEPENDENCY_CHECKS=false
REQUIRE_PERSISTENT_VOLUME=false
